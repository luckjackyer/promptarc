GITHUB_TOKEN=
GITHUB_USER=
GITHUB_REPO=promptarc
GITHUB_BRANCH=main

CLOUDFLARE_TOKEN=
CLOUDFLARE_ZONE_ID=

DOMAIN=www.promptarc.cc
ROOT_DOMAIN=promptarc.cc
CONTACT_EMAIL=
GUMROAD_URL=
NEWSLETTER_ENDPOINT=
CLOUDFLARE_ANALYTICS_TOKEN=

# Image generation. Keep real keys local only; do not commit them.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://www.taikuaila.cn/

# Optional local proxy. The workflow auto-detects common local ports, but explicit values win.
# Common examples: http://127.0.0.1:7890 or http://127.0.0.1:10809
LOCAL_PROXY_PORT=
API_PROXY=
HTTPS_PROXY=
HTTP_PROXY=

# Cloudflare R2 S3 credentials for uploading generated gallery images.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=promptarc-gallery
R2_PUBLIC_BASE=https://img.promptarc.cc

# Cloudflare Worker image generator backend.
CLOUDFLARE_ACCOUNT_ID=
WORKER_NAME=promptarc-image-generator
WORKER_ROUTE=www.promptarc.cc/api/generate-image
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=low
IMAGE_OUTPUT_FORMAT=png

# Optional dedicated deployment proxy. If set, deployment still tries direct first, then this proxy.
DEPLOY_PROXY=
