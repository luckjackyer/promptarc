GITHUB_TOKEN=
GITHUB_USER=
GITHUB_REPO=promptarc
GITHUB_BRANCH=main

CLOUDFLARE_TOKEN=
CLOUDFLARE_ZONE_ID=

DOMAIN=www.promptarc.cc
ROOT_DOMAIN=promptarc.cc
CONTACT_EMAIL=
GUMROAD_URL=
NEWSLETTER_ENDPOINT=
CLOUDFLARE_ANALYTICS_TOKEN=

# Image generation. Keep real keys local only; do not commit them.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://www.taikuaila.cn/

# Image generation proxy. Deployment will try direct first, then can fall back to proxy variables.
API_PROXY=

# Cloudflare R2 S3 credentials for uploading generated gallery images.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=promptarc-gallery
R2_PUBLIC_BASE=https://img.promptarc.cc

# Optional dedicated deployment proxy. If set, deployment still tries direct first, then this proxy.
DEPLOY_PROXY=
